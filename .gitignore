# Rust build output
/target/

# Runtime log files produced by the monitor
*.jsonl

# Runtime config files (contain machine-specific paths — not committed)
monitor.config.json
logs/monitor.config.json

# Exception: the template in config/ IS committed — it is the source of truth
!config/monitor.config.json

# Windows artifacts
*.pdb
*.exp
*.lib
Thumbs.db

# VS Code user settings (tasks.json at root is already tracked)
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# JetBrains / RustRover
.idea/

# Environment / secrets
.env
*.env.local
